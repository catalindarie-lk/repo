{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/FS",
                "${file}",
                "/Fe${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe",
                "/Fo${workspaceFolder}\\obj\\${fileBasenameNoExtension}.obj",
                "/Fd${workspaceFolder}\\pdb\\${fileBasenameNoExtension}.pdb",
                "/link",
                "/PDB:${workspaceFolder}\\pdb\\${fileBasenameNoExtension}.pdb"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}